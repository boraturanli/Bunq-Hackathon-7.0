# Copy this file to .env.local and fill in the values.

# Required — OpenAI API key for GPT-4o receipt parsing
OPENAI_API_KEY=sk-...

# Optional — which vision model to use (defaults to gpt-4o-2024-08-06)
VISION_MODEL=gpt-4o-2024-08-06

# Optional — URL of the Python sandbox backend (defaults to http://localhost:8000)
BUNQ_API_URL=http://localhost:8000
